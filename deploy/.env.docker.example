# ============================================================
#  Docker 运行环境变量模板
#  用法: 复制为 .env.docker 并填写真实值，docker run --env-file 引用
#  注意: 容器内不能用 localhost / 127.0.0.1 指代宿主机的 MySQL/Redis！
#        请填外部可达的 IP（如内网 192.168.x.x）
# ============================================================

# ---------- 数据库（外部 MySQL）----------
DB_HOST=你的MySQL地址
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=project_mgmt

# ---------- JWT 密钥（登录令牌签名，固定且保密，自定义一串随机字符）----------
SECRET_KEY=change-this-to-a-random-string

# ---------- 附件本地存储目录（容器内路径，不用OSS时生效）----------
UPLOAD_DIR=./uploads

# ---------- 可选：企微/OSS 等也可在系统设置界面里配，无需在此填 ----------
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_SECRET=
OSS_ENABLED=false
